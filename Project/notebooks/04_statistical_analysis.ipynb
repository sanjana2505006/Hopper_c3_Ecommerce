                 {
                    "cell_type": "markdown",
                       "metadata": {},
                          "source": ["# 04 — Statistical Analysis\n", "**Project:** Hopper C3 E-Commerce | **Dataset:** UK Online Retail\n"]
                            },
                              {
                                 "cell_type": "code",
                                    "execution_count": null,
                                       "metadata": {},
                                          "outputs": [],
                                             "source": [
                                                 "import pandas as pd\n",
                                                     "import numpy as np\n",
                                                         "import matplotlib.pyplot as plt\n",
                                                             "import seaborn as sns\n",
                                                                 "from scipy import stats\n",
                                                                     "from sklearn.linear_model import LinearRegression\n",
                                                                         "from sklearn.model_selection import train_test_split\n",
                                                                             "from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error\n",
                                                                                 "import statsmodels.api as sm\n",
                                                                                     "import warnings\n",
                                                                                         "warnings.filterwarnings('ignore')\n",
                                                                                             "sns.set_theme(style='whitegrid', palette='Set2')\n",
                                                                                                 "df = pd.read_csv('../cleaned_data.csv', parse_dates=['InvoiceDate'])\n",
                                                                                                     "df['IsWeekend'] = df['Day'].isin(['Saturday','Sunday']).astype(int)\n",
                                                                                                         "df['IsUK'] = (df['Country']=='United Kingdom').astype(int)\n",
                                                                                                             "print(f'Loaded {len(df):,} rows')\n",
                                                                                                                 "df.head(3)"
                                                                                                                    ]
                                                                                                                      },
                                                                                                                        {
                                                                                                                           "cell_type": "markdown",
                                                                                                                              "metadata": {},
                                                                                                                                 "source": ["## 2. Correlation Analysis"]
                                                                                                                                   },
                                                                                                                                     {
                                                                                                                                        "cell_type": "code",
                                                                                                                                           "execution_count": null,
                                                                                                                                              "metadata": {},
                                                                                                                                                 "outputs": [],
                                                                                                                                                    "source": [
                                                                                                                                                        "corr = df[['Quantity','UnitPrice','Revenue','Month']].corr()\n",
                                                                                                                                                            "fig, ax = plt.subplots(figsize=(8,6))\n",
                                                                                                                                                                "mask = np.triu(np.ones_like(corr, dtype=bool))\n",
                                                                                                                                                                    "sns.heatmap(corr, annot=True, fmt='.3f', cmap='RdYlGn', center=0, mask=mask, ax=ax)\n",
                                                                                                                                                                        "ax.set_title('Pearson Correlation Matrix')\n",
                                                                                                                                                                            "plt.tight_layout()\n",
                                                                                                                                                                                "plt.show()\n",
                                                                                                                                                                                    "print(corr['Revenue'].drop('Revenue').sort_values(ascending=False).to_string())"
                                                                                                                                                                                       ]
                                                                                                                                                                                         },
                                                                                                                                                                                           {
                                                                                                                                                                                              "cell_type": "markdown",
                                                                                                                                                                                                 "metadata": {},
                                                                                                                                                                                                    "source": ["## 3. Simple Linear Regression"]
                                                                                                                                                                                                      },
                                                                                                                                                                                                        {
                                                                                                                                                                                                           "cell_type": "code",
                                                                                                                                                                                                              "execution_count": null,
                                                                                                                                                                                                                 "metadata": {},
                                                                                                                                                                                                                    "outputs": [],
                                                                                                                                                                                                                       "source": [
                                                                                                                                                                                                                           "r = df[(df.Quantity>0)&(df.Revenue>0)].copy()\n",
                                                                                                                                                                                                                               "r['lQ'] = np.log1p(r.Quantity)\n",
                                                                                                                                                                                                                                   "r['lR'] = np.log1p(r.Revenue)\n",
                                                                                                                                                                                                                                       "Xtr,Xte,ytr,yte = train_test_split(r[['lQ']],r.lR,test_size=0.2,random_state=42)\n",
                                                                                                                                                                                                                                           "mod = LinearRegression().fit(Xtr,ytr)\n",
                                                                                                                                                                                                                                               "yp = mod.predict(Xte)\n",
                                                                                                                                                                                                                                                   "print(f'R2={r2_score(yte,yp):.4f} MAE={mean_absolute_error(yte,yp):.4f}')"
                                                                                                                                                                                                                                                      ]
                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                          {
                                                                                                                                                                                                                                                             "cell_type": "markdown",
                                                                                                                                                                                                                                                                "metadata": {},
                                                                                                                                                                                                                                                                   "source": ["## 4. Multiple Regression (OLS)"]
                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                       {
                                                                                                                                                                                                                                                                          "cell_type": "code",
                                                                                                                                                                                                                                                                             "execution_count": null,
                                                                                                                                                                                                                                                                                "metadata": {},
                                                                                                                                                                                                                                                                                   "outputs": [],
                                                                                                                                                                                                                                                                                      "source": [
                                                                                                                                                                                                                                                                                          "r['lUP'] = np.log1p(r.UnitPrice)\n",
                                                                                                                                                                                                                                                                                              "X = sm.add_constant(r[['lQ','lUP','Month','IsWeekend','IsUK']])\n",
                                                                                                                                                                                                                                                                                                  "ols = sm.OLS(r.lR, X).fit()\n",
                                                                                                                                                                                                                                                                                                      "print(ols.summary())"
                                                                                                                                                                                                                                                                                                         ]
                                                                                                                                                                                                                                                                                                           },
                                                                                                                                                                                                                                                                                                             {
                                                                                                                                                                                                                                                                                                                "cell_type": "markdown",
                                                                                                                                                                                                                                                                                                                   "metadata": {},
                                                                                                                                                                                                                                                                                                                      "source": ["## 5. Hypothesis Testing"]
                                                                                                                                                                                                                                                                                                                        },
                                                                                                                                                                                                                                                                                                                          {
                                                                                                                                                                                                                                                                                                                             "cell_type": "code",
                                                                                                                                                                                                                                                                                                                                "execution_count": null,
                                                                                                                                                                                                                                                                                                                                   "metadata": {},
                                                                                                                                                                                                                                                                                                                                      "outputs": [],
                                                                                                                                                                                                                                                                                                                                         "source": [
                                                                                                                                                                                                                                                                                                                                             "iv = df.groupby(['InvoiceNo','IsWeekend']).Revenue.sum().reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                 "t,p = stats.ttest_ind(iv[iv.IsWeekend==0].Revenue,iv[iv.IsWeekend==1].Revenue,equal_var=False)\n",
                                                                                                                                                                                                                                                                                                                                                     "print(f'Weekday vs Weekend: p={p:.4f}')\n",
                                                                                                                                                                                                                                                                                                                                                         "ig = df.groupby(['InvoiceNo','IsUK']).Revenue.sum().reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                             "u,pm = stats.mannwhitneyu(ig[ig.IsUK==1].Revenue,ig[ig.IsUK==0].Revenue,alternative='two-sided')\n",
                                                                                                                                                                                                                                                                                                                                                                 "print(f'UK vs International: p={pm:.4f}')\n",
                                                                                                                                                                                                                                                                                                                                                                     "im = df.groupby(['InvoiceNo','Month']).Revenue.sum().reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                                         "f,pa = stats.f_oneway(*[g.Revenue.values for _,g in im.groupby('Month')])\n",
                                                                                                                                                                                                                                                                                                                                                                             "print(f'Monthly ANOVA: p={pa:.4f}')"
                                                                                                                                                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                                                                                                                                                  },
                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                       "cell_type": "markdown",
                                                                                                                                                                                                                                                                                                                                                                                          "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                             "source": ["## 6. Seasonality"]
                                                                                                                                                                                                                                                                                                                                                                                               },
                                                                                                                                                                                                                                                                                                                                                                                                 {
                                                                                                                                                                                                                                                                                                                                                                                                    "cell_type": "code",
                                                                                                                                                                                                                                                                                                                                                                                                       "execution_count": null,
                                                                                                                                                                                                                                                                                                                                                                                                          "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                             "outputs": [],
                                                                                                                                                                                                                                                                                                                                                                                                                "source": [
                                                                                                                                                                                                                                                                                                                                                                                                                    "mo = df.groupby(df.InvoiceDate.dt.to_period('M')).Revenue.sum().reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                                                                                        "mo['InvoiceDate'] = mo.InvoiceDate.astype(str)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                            "mo['Roll3'] = mo.Revenue.rolling(3,center=True).mean()\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                "fig,ax = plt.subplots(figsize=(14,5))\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                    "ax.bar(mo.InvoiceDate,mo.Revenue,color='lightsteelblue',label='Monthly')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                        "ax.plot(mo.InvoiceDate,mo.Roll3,color='red',lw=2,marker='o',ms=4,label='3M Avg')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                            "ax.set_title('Monthly Revenue with 3-Month Rolling Average')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                "plt.xticks(rotation=45,ha='right'); ax.legend(); plt.tight_layout(); plt.show()"
                                                                                                                                                                                                                                                                                                                                                                                                                                                   ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                     },
                                                                                                                                                                                                                                                                                                                                                                                                                                                       {
                                                                                                                                                                                                                                                                                                                                                                                                                                                          "cell_type": "markdown",
