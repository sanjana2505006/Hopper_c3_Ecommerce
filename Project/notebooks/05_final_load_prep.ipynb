                 {
                    "cell_type": "markdown",
                       "metadata": {},
                          "source": ["# 05 — KPI Computation & Final Data Load\n", "**Project:** Hopper C3 E-Commerce | **Dataset:** UK Online Retail\n", "**Goal:** Compute all business KPIs and export Tableau-ready flat files.\n"]
                            },
                              {
                                 "cell_type": "code",
                                    "execution_count": null,
                                       "metadata": {},
                                          "outputs": [],
                                             "source": [
                                                 "import pandas as pd\n",
                                                     "import numpy as np\n",
                                                         "import matplotlib.pyplot as plt\n",
                                                             "import matplotlib.ticker as mticker\n",
                                                                 "from pathlib import Path\n",
                                                                     "import warnings\n",
                                                                         "warnings.filterwarnings('ignore')\n",
                                                                             "\n",
                                                                                 "OUTPUT_DIR = Path('../tableau_data')\n",
                                                                                     "OUTPUT_DIR.mkdir(exist_ok=True)\n",
                                                                                         "\n",
                                                                                             "df = pd.read_csv('../cleaned_data.csv', parse_dates=['InvoiceDate'])\n",
                                                                                                 "df['YearMonth'] = df['InvoiceDate'].dt.to_period('M').astype(str)\n",
                                                                                                     "df['IsWeekend'] = df['Day'].isin(['Saturday','Sunday'])\n",
                                                                                                         "print(f'Loaded {len(df):,} rows | {df.InvoiceDate.min().date()} to {df.InvoiceDate.max().date()}')\n",
                                                                                                             "df.head(3)"
                                                                                                                ]
                                                                                                                  },
                                                                                                                    {
                                                                                                                       "cell_type": "markdown",
                                                                                                                          "metadata": {},
                                                                                                                             "source": ["## 2. Core Revenue KPIs"]
                                                                                                                               },
                                                                                                                                 {
                                                                                                                                    "cell_type": "code",
                                                                                                                                       "execution_count": null,
                                                                                                                                          "metadata": {},
                                                                                                                                             "outputs": [],
                                                                                                                                                "source": [
                                                                                                                                                    "total_revenue = df['Revenue'].sum()\n",
                                                                                                                                                        "total_orders = df['InvoiceNo'].nunique()\n",
                                                                                                                                                            "aov = total_revenue / total_orders\n",
                                                                                                                                                                "monthly_rev = df.groupby('YearMonth')['Revenue'].sum().sort_index()\n",
                                                                                                                                                                    "mom_growth = monthly_rev.pct_change().mean() * 100\n",
                                                                                                                                                                        "\n",
                                                                                                                                                                            "print('=== REVENUE KPIs ===')\n",
                                                                                                                                                                                "print(f'  Total Revenue       : GBP {total_revenue:,.2f}')\n",
                                                                                                                                                                                    "print(f'  Total Orders        : {total_orders:,}')\n",
                                                                                                                                                                                        "print(f'  Avg Order Value     : GBP {aov:,.2f}')\n",
                                                                                                                                                                                            "print(f'  Total Units Sold    : {df[\"Quantity\"].sum():,}')\n",
                                                                                                                                                                                                "print(f'  Avg MoM Growth      : {mom_growth:.1f}%')\n",
                                                                                                                                                                                                    "print(f'  Best Month          : {monthly_rev.idxmax()}')\n",
                                                                                                                                                                                                        "print(f'  Worst Month         : {monthly_rev.idxmin()}')"
                                                                                                                                                                                                           ]
                                                                                                                                                                                                             },
                                                                                                                                                                                                               {
                                                                                                                                                                                                                  "cell_type": "markdown",
                                                                                                                                                                                                                     "metadata": {},
                                                                                                                                                                                                                        "source": ["## 3. Customer KPIs"]
                                                                                                                                                                                                                          },
                                                                                                                                                                                                                            {
                                                                                                                                                                                                                               "cell_type": "code",
                                                                                                                                                                                                                                  "execution_count": null,
                                                                                                                                                                                                                                     "metadata": {},
                                                                                                                                                                                                                                        "outputs": [],
                                                                                                                                                                                                                                           "source": [
                                                                                                                                                                                                                                               "cust = df.groupby('CustomerID').agg(\n",
                                                                                                                                                                                                                                                   "    TotalSpend=('Revenue','sum'),\n",
                                                                                                                                                                                                                                                       "    NumOrders=('InvoiceNo','nunique'),\n",
                                                                                                                                                                                                                                                           "    FirstPurchase=('InvoiceDate','min'),\n",
                                                                                                                                                                                                                                                               "    LastPurchase=('InvoiceDate','max')\n",
                                                                                                                                                                                                                                                                   ").reset_index()\n",
                                                                                                                                                                                                                                                                       "cust['AvgOrderValue'] = cust['TotalSpend'] / cust['NumOrders']\n",
                                                                                                                                                                                                                                                                           "cust['LifespanDays'] = (cust['LastPurchase'] - cust['FirstPurchase']).dt.days\n",
                                                                                                                                                                                                                                                                               "repeat = (cust['NumOrders'] > 1).sum()\n",
                                                                                                                                                                                                                                                                                   "\n",
                                                                                                                                                                                                                                                                                       "print('=== CUSTOMER KPIs ===')\n",
                                                                                                                                                                                                                                                                                           "print(f'  Total Customers     : {len(cust):,}')\n",
                                                                                                                                                                                                                                                                                               "print(f'  Repeat Buyers       : {repeat:,}')\n",
                                                                                                                                                                                                                                                                                                   "print(f'  Repeat Rate         : {repeat/len(cust)*100:.1f}%')\n",
                                                                                                                                                                                                                                                                                                       "print(f'  Avg CLV             : GBP {cust[\"TotalSpend\"].mean():,.2f}')\n",
                                                                                                                                                                                                                                                                                                           "print(f'  Median CLV          : GBP {cust[\"TotalSpend\"].median():,.2f}')\n",
                                                                                                                                                                                                                                                                                                               "print(f'  Avg Orders/Customer : {cust[\"NumOrders\"].mean():.2f}')"
                                                                                                                                                                                                                                                                                                                  ]
                                                                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                                                                      {
                                                                                                                                                                                                                                                                                                                         "cell_type": "markdown",
                                                                                                                                                                                                                                                                                                                            "metadata": {},
                                                                                                                                                                                                                                                                                                                               "source": ["## 4. RFM Segmentation"]
                                                                                                                                                                                                                                                                                                                                 },
                                                                                                                                                                                                                                                                                                                                   {
                                                                                                                                                                                                                                                                                                                                      "cell_type": "code",
                                                                                                                                                                                                                                                                                                                                         "execution_count": null,
                                                                                                                                                                                                                                                                                                                                            "metadata": {},
                                                                                                                                                                                                                                                                                                                                               "outputs": [],
                                                                                                                                                                                                                                                                                                                                                  "source": [
                                                                                                                                                                                                                                                                                                                                                      "snap = df['InvoiceDate'].max() + pd.Timedelta(days=1)\n",
                                                                                                                                                                                                                                                                                                                                                          "rfm = df.groupby('CustomerID').agg(\n",
                                                                                                                                                                                                                                                                                                                                                              "    Recency=('InvoiceDate', lambda x: (snap-x.max()).days),\n",
                                                                                                                                                                                                                                                                                                                                                                  "    Frequency=('InvoiceNo','nunique'),\n",
                                                                                                                                                                                                                                                                                                                                                                      "    Monetary=('Revenue','sum')\n",
                                                                                                                                                                                                                                                                                                                                                                          ").reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                                              "rfm['R'] = pd.qcut(rfm['Recency'], 4, labels=[4,3,2,1]).astype(int)\n",
                                                                                                                                                                                                                                                                                                                                                                                  "rfm['F'] = pd.qcut(rfm['Frequency'].rank(method='first'), 4, labels=[1,2,3,4]).astype(int)\n",
                                                                                                                                                                                                                                                                                                                                                                                      "rfm['M'] = pd.qcut(rfm['Monetary'], 4, labels=[1,2,3,4]).astype(int)\n",
                                                                                                                                                                                                                                                                                                                                                                                          "rfm['Score'] = rfm['R'] + rfm['F'] + rfm['M']\n",
                                                                                                                                                                                                                                                                                                                                                                                              "rfm['Segment'] = rfm['Score'].apply(lambda s: 'Champions' if s>=10 else 'Loyal' if s>=7 else 'At Risk' if s>=5 else 'Lost')\n",
                                                                                                                                                                                                                                                                                                                                                                                                  "print(rfm.groupby('Segment')[['Recency','Frequency','Monetary']].mean().round(1).to_string())"
                                                                                                                                                                                                                                                                                                                                                                                                     ]
                                                                                                                                                                                                                                                                                                                                                                                                       },
                                                                                                                                                                                                                                                                                                                                                                                                         {
                                                                                                                                                                                                                                                                                                                                                                                                            "cell_type": "markdown",
                                                                                                                                                                                                                                                                                                                                                                                                               "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                                  "source": ["## 5. Product & Geographic KPIs"]
                                                                                                                                                                                                                                                                                                                                                                                                                    },
                                                                                                                                                                                                                                                                                                                                                                                                                      {
                                                                                                                                                                                                                                                                                                                                                                                                                         "cell_type": "code",
                                                                                                                                                                                                                                                                                                                                                                                                                            "execution_count": null,
                                                                                                                                                                                                                                                                                                                                                                                                                               "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                                                  "outputs": [],
                                                                                                                                                                                                                                                                                                                                                                                                                                     "source": [
                                                                                                                                                                                                                                                                                                                                                                                                                                         "prod = df.groupby(['StockCode','Description']).agg(\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                             "    Revenue=('Revenue','sum'), Qty=('Quantity','sum'), Orders=('InvoiceNo','nunique')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                 ").reset_index().sort_values('Revenue', ascending=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                     "\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                         "geo = df.groupby('Country').agg(\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                             "    Revenue=('Revenue','sum'), Orders=('InvoiceNo','nunique'), Customers=('CustomerID','nunique')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                 ").reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "geo['RevShare'] = geo['Revenue'] / geo['Revenue'].sum() * 100\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                         "geo = geo.sort_values('Revenue', ascending=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 "print('=== PRODUCT KPIs ===')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "print(f'  Total Products      : {len(prod):,}')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         "print(f'  Top Product         : {prod.iloc[0][\"Description\"][:40]}')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "print(f'  Top Product Rev     : GBP {prod.iloc[0][\"Revenue\"]:,.2f}')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 "top20 = int(len(prod)*0.2)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "print(f'  Pareto (top 20%)    : {prod.head(top20)[\"Revenue\"].sum()/prod[\"Revenue\"].sum()*100:.1f}% of revenue')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         "print(f'\\n=== TOP 5 COUNTRIES ===')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             "for _,r in geo.head(5).iterrows():\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 "    print(f'  {r.Country:<25}: GBP {r.Revenue:>12,.0f} ({r.RevShare:.1f}%)')"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           "cell_type": "markdown",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 "source": ["## 6. Monthly KPI Table"]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "cell_type": "code",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           "execution_count": null,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 "outputs": [],
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "source": [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "monthly_kpi = df.groupby('YearMonth').agg(\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "    Revenue=('Revenue','sum'),\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "    Orders=('InvoiceNo','nunique'),\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "    Customers=('CustomerID','nunique'),\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "    UnitsSold=('Quantity','sum')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            ").reset_index()\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                "monthly_kpi['AOV'] = monthly_kpi['Revenue'] / monthly_kpi['Orders']\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    "monthly_kpi['MoM'] = monthly_kpi['Revenue'].pct_change() * 100\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "monthly_kpi['CumRevenue'] = monthly_kpi['Revenue'].cumsum()\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "print(monthly_kpi.round(2).to_string(index=False))"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                 },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "cell_type": "markdown",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "source": ["## 7. Export Tableau-Ready CSVs"]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   "cell_type": "code",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "execution_count": null,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                         "metadata": {},
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "outputs": [],
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               "source": [
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   "df.to_csv(OUTPUT_DIR / 'fact_sales.csv', index=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       "print(f'fact_sales.csv          ({len(df):,} rows)')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           "monthly_kpi.to_csv(OUTPUT_DIR / 'kpi_monthly.csv', index=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               "print(f'kpi_monthly.csv         ({len(monthly_kpi)} rows)')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   "prod.to_csv(OUTPUT_DIR / 'dim_products.csv', index=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       "print(f'dim_products.csv        ({len(prod):,} rows)')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           "rfm.to_csv(OUTPUT_DIR / 'dim_customers_rfm.csv', index=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                               "print(f'dim_customers_rfm.csv   ({len(rfm):,} rows)')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   "geo.to_csv(OUTPUT_DIR / 'dim_geography.csv', index=False)\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       "print(f'dim_geography.csv       ({len(geo)} rows)')\n",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                           "print('All Tableau-ready files exported to ../tableau_data/')"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              ]
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                },
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                     "cell_type": "markdown",
